{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "Debug",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "Release",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "STM32",
            "toolchainFile": "CMakeModules/cmake/toolchain-arm-none-eabi-gcc.cmake",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "ARCH": "-mcpu=cortex-m7",
                "CMAKE_BUILD_TYPE": "Release",
                "UNITY_BUILD": "ON"
            }
        }
    ]
}